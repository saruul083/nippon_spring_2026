BEGIN
    OUTPUT "Please enter any number(1-10), enter 0 to quit"
    INPUT n
    if n < 10 && n != 0
        while 1 < n AND n < 10 
            FOR counter = 1 to 10
                SET SUM = n * counter
                OUTPUT n + "*" + counter + "=" = SUM
            ENDFOR
            OUTPUT "Please enter any number(1-10), enter 0 to quit"
            INPUT n
        ENDWHILE
    elif n = 0
        EXIT
    ENDIF
END